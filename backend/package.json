{
  "name": "monitoring-backend",
  "version": "1.0.0",
  "description": "Backend Express pour le projet Monitoring (CRUD devices avec Drizzle ORM, Winston et PM2)",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "pm2:start": "pm2 start src/app.js --name monitoring-express",
    "pm2:stop": "pm2 stop monitoring-express",
    "pm2:restart": "pm2 restart monitoring-express",
    "pm2:logs": "pm2 logs monitoring-express"
  },
  "keywords": [
    "express",
    "monitoring",
    "drizzle-orm",
    "mysql",
    "pm2",
    "winston",
    "backend"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "express": "^5.1.0",
    "joi": "^18.0.1",
    "multer": "^2.0.2",
    "mysql2": "^3.14.5",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "pm2": "^5.4.2"
  }
}
